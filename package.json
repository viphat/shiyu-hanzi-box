{
  "name": "shiyu-hanzi-box",
  "description": "Capture Chinese words and quotes while reading; export daily Markdown notes.",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "build:dictionary": "tsx scripts/build-dictionary.ts",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "lucide-react": "^1.21.0",
    "opencc-js": "^1.3.1",
    "pinyin-pro": "^3.28.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-fsrs": "5.4.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/opencc-js": "^1.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@webext-core/fake-browser": "^1.5.2",
    "@wxt-dev/auto-icons": "^1.1.1",
    "@wxt-dev/module-react": "^1.1.5",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "wxt": "^0.20.26"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "shell-quote": "1.8.4",
    "tmp": "0.2.7",
    "uuid": "11.1.1"
  }
}
